<div class="mt-4">
  <h1>Tasks</h1>
  <%= link_to "New Task", new_task_path, class: "btn btn-primary mb-3" %>
  <table class="table table-striped">
    <thead>
      <tr>
        <th>Title</th>
        <th>Description</th>
        <th>Status</th>
        <th>File</th>
        <th>Actions</th>
      </tr>
    </thead>
    <tbody>
      <% @tasks.each do |task| %>
        <tr>
          <td><%= task.title %></td>
          <td><%= task.description %></td>
          <td><%= task.completed ? "Completed" : "Not Completed" %></td>
          <td>
            <% if task.file.attached? %>
              <%= link_to task.file.filename, rails_blob_path(task.file, disposition: "attachment") %>
            <% end %>
          </td>
          <td>
            <%= link_to "Show", task_path(task), class: "btn btn-info btn-sm" %>
            <%= link_to "Edit", edit_task_path(task), class: "btn btn-warning btn-sm" %>
            <%= link_to "Delete", task_path(task), class: "btn btn-danger btn-sm", data: { turbo_method: :delete, turbo_confirm: "Are you sure you want to delete this task?" } %>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>