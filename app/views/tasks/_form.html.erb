<%= form_with(model: task, class: "form") do |form| %>
  <% if task.errors.any? %>
    <div class="alert alert-danger">
      <h4><%= pluralize(task.errors.count, "error") %> prohibited this task from being saved:</h4>
      <ul>
        <% task.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="mb-3">
    <%= form.label :title, class: "form-label" %>
    <%= form.text_field :title, class: "form-control" %>
  </div>

  <div class="mb-3">
    <%= form.label :description, class: "form-label" %>
    <%= form.text_area :description, class: "form-control", rows: 4 %>
  </div>

  <div class="mb-3">
    <%= form.label :completed, class: "form-check-label" %>
    <%= form.check_box :completed, class: "form-check-input" %>
  </div>

  <div class="mb-3">
    <%= form.label :file, class: "form-label" %>
    <% if task.file.attached? && task.file.persisted? %>
      <p>
        <strong>Current file:</strong>
        <%= link_to task.file.filename, rails_blob_path(task.file, disposition: "attachment") %>
      </p>
      <div class="form-check">
        <%= form.check_box :remove_file, class: "form-check-input" %>
        <%= form.label :remove_file, "Remove current file", class: "form-check-label" %>
      </div>
    <% end %>
    <%= form.file_field :file, class: "form-control", accept: "image/png,image/jpeg,image/webp,application/pdf,text/plain,application/zip" %>
    <small class="form-text text-muted">Allowed formats: PNG, JPEG, WEBP, PDF, TXT, ZIP (max 25MB).</small>
  </div>

  <div>
    <%= form.submit class: "btn btn-primary" %>
    <%= link_to "Back", tasks_path, class: "btn btn-secondary" %>
  </div>
<% end %>